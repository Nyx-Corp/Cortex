{#
    List layout component - to be used inside page_content block.

    The parent template should define:
    - page_icon: The list icon
    - page_title: The list title
    - page_content: Embed this template

    Usage in index.html.twig:
    {% block page_icon %}<i data-lucide="users" class="size-6 text-primary"></i>{% endblock %}
    {% block page_title %}Contacts{% endblock %}
    {% block page_content %}
        {% embed '@_theme/layout/list.html.twig' %}
            {% block create_link %}{{ path('admin/contact/create') }}{% endblock %}
            {% block email_th %}Email{% endblock %}
            {% block email_td %}{{ item.email }}{% endblock %}
            ...
        {% endembed %}
    {% endblock %}
#}

{% trans_default_domain trans_default_domain ?? 'admin' %}

{% form_theme form '@_theme/components/filters.html.twig' %}

{{ form_start(form, {
    'action': path(app.request.attributes.get('_route'), app.request.attributes.get('_route_params', {})),
    'attr': {
        'id': '_collectionDecoratorForm',
        'class': 'flex-1 flex flex-col min-h-0',
    }
}) }}
<div class="flex-1 flex flex-col min-h-0 overflow-hidden">
    {# Toolbar: Search + Batch Actions + Create button #}
    <div class="flex items-center gap-3 mb-2">
        {# Search box with filters popover - Stimulus controller #}
        <div class="search-filters flex-1 max-w-[50%] relative" data-controller="search-filters">
            <div class="flex items-center gap-2">
                <div class="flex items-center bg-white border border-zinc-200 rounded-lg shadow-sm focus-within:border-primary focus-within:ring-2 focus-within:ring-primary/10 transition-all flex-1">
                    <div class="flex items-center gap-2 px-3 py-2 flex-1">
                        <i data-lucide="search" class="size-4 text-zinc-400 shrink-0"></i>
                        {{ form_widget(form.q, {
                            value: app.request.query.get('q', ''),
                            attr: {
                                placeholder: 'Filtrer la liste...',
                                class: 'flex-1 bg-transparent border-0 outline-none text-sm text-zinc-700 placeholder:text-zinc-400',
                                'data-search-filters-target': 'input',
                                'data-action': 'keydown.enter->search-filters#submitOnEnter',
                                autocomplete: 'off'
                            }
                        }) }}
                    </div>
                    {% if form.vars.filters|default({})|length > 0 %}
                    <div class="flex items-center border-l border-zinc-200">
                        <button
                            type="button"
                            class="flex items-center gap-1.5 px-2.5 py-2 text-zinc-400 hover:text-zinc-600 hover:bg-zinc-50 rounded-r-lg transition-colors cursor-pointer"
                            data-search-filters-target="toggleBtn"
                            data-action="click->search-filters#toggle"
                            data-tooltip="Filtres avancés"
                            data-tooltip-position="bottom"
                        >
                            <i data-lucide="sliders-horizontal" class="size-4"></i>
                            <kbd>F</kbd>
                        </button>
                    </div>
                    {% endif %}
                </div>
                {# Info button - outside, circle style #}
                <button
                    type="button"
                    class="size-9 flex items-center justify-center text-zinc-400 hover:text-zinc-600 hover:bg-zinc-100 rounded-full transition-colors cursor-pointer group relative shrink-0"
                    title="Syntaxe de recherche"
                >
                    <i data-lucide="info" class="size-4"></i>
                    {# Tooltip #}
                    <div class="absolute right-0 top-full mt-2 w-72 p-3 bg-zinc-800 text-white text-xs border border-zinc-700 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-50">
                        <div class="font-medium mb-2">Syntaxe de recherche</div>
                        <div class="space-y-1.5 text-zinc-300">
                            <div><code class="bg-zinc-700 px-1">nom:dupont</code> Filtre par champ</div>
                            <div><code class="bg-zinc-700 px-1">nom:"jean dupont"</code> Valeur avec espaces</div>
                            <div><code class="bg-zinc-700 px-1">email:@gmail.com</code> Recherche partielle</div>
                        </div>
                        <div class="absolute -top-1.5 right-4 w-3 h-3 bg-zinc-800 border-l border-t border-zinc-700 rotate-45"></div>
                    </div>
                </button>
            </div>
            {# Filters popover - flat square style with subtle shadow #}
            {% if form.vars.filters|default({})|length > 0 %}
            <div class="hidden absolute top-full left-0 right-0 mt-2 p-4 bg-white border border-zinc-200 shadow-md z-50"
                 data-search-filters-target="popover">
                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
                    {% for name, filter in form.vars.filters %}
                        {{ form_row(filter, {
                            attr: filter.vars.attr|merge({
                                'data-search-filters-target': 'field',
                                'data-filter-field': name,
                                'data-action': 'keydown.enter->search-filters#applyOnEnter'
                            })
                        }) }}
                    {% endfor %}
                </div>
                <div class="flex items-center justify-end gap-2 mt-4 pt-4 border-t border-zinc-100">
                    <button type="button"
                            class="px-3 py-1.5 text-sm text-zinc-600 hover:bg-zinc-100 transition-colors"
                            data-action="click->search-filters#reset">
                        Réinitialiser
                    </button>
                    <button type="button"
                            class="px-3 py-1.5 text-sm bg-primary text-white hover:bg-primary/90 transition-colors"
                            data-action="click->search-filters#applyFilters">
                        Appliquer
                    </button>
                </div>
            </div>
            {% endif %}
        </div>

        {# Export button - flat square style #}
        <button
            type="button"
            class="ml-auto inline-flex items-center gap-2 px-3 py-1.5 text-sm border border-zinc-200 bg-white hover:bg-zinc-50 transition-colors cursor-pointer"
            data-batch-action="export"
            data-tooltip="Exporter la liste"
            data-tooltip-position="bottom"
        >
            <i data-lucide="download" class="size-4 text-zinc-500"></i>
            <span class="text-zinc-700">Exporter</span>
        </button>

        {# Create button - flat square style #}
        <a href="{% block create_link '#' %}" data-shortcut="n"
            class="inline-flex items-center gap-2 px-3 py-1.5 text-sm bg-primary hover:bg-primary/90 text-white transition-colors cursor-pointer shrink-0">
            <i data-lucide="plus" class="size-4"></i>
            <span>{{ 'admin.action.new'|trans({}, 'admin') }}</span>
            <kbd class="!bg-white/20 !border-white/30 !text-white/80">N</kbd>
        </a>
    </div>

    {# Active filters display - uses active_filters from ModelQueryDecorator #}
    {% block active_filters %}
    {% set active_filters = form.vars.active_filters|default([]) %}
    {% if active_filters|length > 0 %}
    <div class="flex items-center gap-2 py-2 flex-wrap">
        {% for filter in active_filters %}
        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 text-xs bg-primary/10 text-primary rounded-full border border-primary/20">
            <span class="font-medium">{{ filter.label }}</span>
            <span class="text-primary/70">{{ filter.display|default(filter.value) }}</span>
            <button type="button"
                    class="text-primary/50 hover:text-primary ml-0.5 transition-colors cursor-pointer"
                    data-action="click->search-filters#removeFilter"
                    data-filter-field="{{ filter.field }}">
                <i data-lucide="x" class="size-3"></i>
            </button>
        </span>
        {% endfor %}
        <a href="{{ path(app.request.attributes.get('_route')) }}"
           class="text-xs text-zinc-500 hover:text-primary transition-colors underline underline-offset-2">
            {{ 'admin.list.reset'|trans({}, 'admin') }}
        </a>
    </div>
    {% endif %}
    {% endblock %}

    {# Table card #}
    <div class="border border-zinc-200 bg-white min-h-0 flex-1 flex flex-col overflow-hidden mt-4">
        {# Table content - scrollable #}
        <div class="overflow-auto flex-1">
        {% block table %}
            <table class="min-w-full text-sm text-left">
                <thead class="bg-zinc-50 sticky top-0 z-10 font-heading">
                    <tr class="border-b border-zinc-200">
                        <th scope="col" class="pl-4 py-1.5 w-10 align-middle">
                            <input type="checkbox" id="select-all"
                                class="size-4 rounded border-zinc-300 text-primary accent-primary focus:ring-primary/20 focus:ring-2 cursor-pointer"
                                data-action="change->batch#toggleAll">
                        </th>
                    {% for field in form.vars.fields %}
                        {% if block(field ~ '_th') ?? null %}
                        <th scope="col" class="px-4 py-1.5 text-xs font-medium text-zinc-500 uppercase tracking-wider whitespace-nowrap align-middle">
                            <div class="flex items-center gap-2">
                                <span>{{ block(field ~ '_th') }}</span>
                            {% if form.vars.sorts[field] is defined %}
                                <div class="sort flex items-center gap-0 ml-2">
                                    {# Manual rendering of sort radio buttons to avoid form re-rendering issues #}
                                    {% for direction, sortData in form.vars.sorts[field] %}
                                        {% set icon = direction == 'asc' ? 'chevron-up' : 'chevron-down' %}
                                        <label class="cursor-pointer {{ sortData.checked ? 'text-heart' : 'text-dark-lighter' }} hover:text-heart transition-colors">
                                            <input type="radio" class="sr-only" name="{{ sortData.name }}" value="{{ sortData.value }}" data-autosubmit="true" {{ sortData.checked ? 'checked' : '' }}>
                                            <i data-lucide="{{ icon }}" class="{{ sortData.checked ? 'size-5' : 'size-4' }}"></i>
                                        </label>
                                    {% endfor %}
                                </div>
                            {% endif %}
                            </div>
                        </th>
                        {% endif %}
                    {% endfor %}
                        <th scope="col" class="px-4 py-1.5 w-32 text-right align-middle">
                            {# Batch actions dropdown - visible when items selected #}
                            <div class="relative inline-block" data-batch-dropdown>
                                <button
                                    type="button"
                                    class="inline-flex items-center gap-2 px-3 py-1.5 text-sm font-normal border border-transparent bg-primary/10 text-primary hover:bg-primary/20 transition-colors opacity-0 pointer-events-none"
                                    style="font-family: var(--font-sans);"
                                    data-batch-actions-trigger
                                >
                                    <i data-lucide="check-square" class="size-4"></i>
                                    <span data-batch-count>0</span>
                                    <span>sélectionné(s)</span>
                                    <i data-lucide="chevron-down" class="size-3.5"></i>
                                </button>
                                <div
                                    class="absolute top-full right-0 mt-1 w-48 bg-white border border-zinc-200 shadow-md z-50 hidden overflow-hidden py-1"
                                    style="font-family: var(--font-sans); font-weight: 400;"
                                    data-batch-menu
                                >
                                    {% block batch_actions %}
                                    <button type="button" class="w-full flex items-center gap-3 px-4 py-2 text-sm text-zinc-600 hover:bg-zinc-50 transition-colors" data-batch-action="export">
                                        <i data-lucide="download" class="size-4 text-zinc-400"></i>
                                        Exporter
                                    </button>
                                    <button type="button" class="w-full flex items-center gap-3 px-4 py-2 text-sm text-zinc-600 hover:bg-zinc-50 transition-colors" data-batch-action="email">
                                        <i data-lucide="mail" class="size-4 text-zinc-400"></i>
                                        Envoyer un email
                                    </button>
                                    {# Batch archive action - only if model is archivable #}
                                    {% if collection|first.archivedAt is defined %}
                                    <div class="my-1 mx-4 border-t border-zinc-100"></div>
                                    <button type="button" class="w-full flex items-center gap-3 px-4 py-2 text-sm text-red-600 hover:bg-red-50 transition-colors" data-batch-action="archive">
                                        <i data-lucide="archive" class="size-4"></i>
                                        Archiver
                                    </button>
                                    {% endif %}
                                    {% endblock %}
                                </div>
                            </div>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    {% if collection is empty %}
                        <tr>
                            <td colspan="100%" class="px-4 py-12 text-center text-sm text-zinc-500">
                                <div class="flex flex-col items-center gap-3">
                                    <i data-lucide="inbox" class="size-12 text-zinc-300"></i>
                                    {% block empty_text 'admin.list.empty_text'|trans({}, 'admin') %}
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        {% for item in collection %}
                            <tr class="{{ loop.index is odd ? 'bg-white' : 'bg-zinc-50' }} hover:bg-spade/10 transition-colors group">
                                <td class="pl-4 py-2 w-10 align-top pt-3.5">
                                    <input type="checkbox" name="selected_items[]" value="{{ item.uuid }}"
                                        class="row-checkbox size-4 rounded border-zinc-300 text-primary accent-primary focus:ring-primary/20 focus:ring-2 cursor-pointer"
                                        data-action="change->batch#toggle">
                                </td>
                            {% for field in form.vars.fields %}
                                {# Check _th existence to ensure column alignment even when _td content is empty #}
                                {% if block(field ~ '_th') ?? null %}
                                <td class="px-4 py-2 whitespace-nowrap text-sm text-zinc-700 align-middle">
                                    {{ block(field ~ '_td') ?? '' }}
                                </td>
                                {% endif %}
                            {% endfor %}
                                <td class="px-4 py-2 text-right align-middle">
                                {% block row_actions %}
                                    <div class="inline-flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                                        {# Edit button - heart red #}
                                        <a href="{{ app.request.pathInfo|trim('s') ~ '/' ~ item.uuid ~ '/edit' }}"
                                           class="size-7 inline-flex items-center justify-center border border-heart/30 text-heart hover:bg-heart/10 transition-colors"
                                           data-tooltip="{{ 'admin.action.edit'|trans({}, 'admin') }}">
                                            <i data-lucide="pencil" class="size-4"></i>
                                        </a>
                                        {# More actions dropdown - no border, baseline #}
                                        <div class="relative" data-controller="dropdown">
                                            <button type="button"
                                                    class="size-7 inline-flex items-center justify-center text-zinc-400 hover:text-zinc-600 transition-colors cursor-pointer"
                                                    data-dropdown-target="trigger"
                                                    data-tooltip="Plus d'actions">
                                                <i data-lucide="more-horizontal" class="size-4"></i>
                                            </button>
                                            <div class="hidden absolute right-0 top-full mt-1 w-44 bg-white border border-zinc-200 shadow-md z-50 py-1 overflow-hidden"
                                                 data-dropdown-target="menu">
                                                {# Archive action - only if model is archivable #}
                                                {% if item.archivedAt is defined %}
                                                <a href="{{ app.request.pathInfo|trim('s') ~ '/' ~ item.uuid ~ '/archive' }}"
                                                   class="flex items-center gap-2 px-3 py-2 text-sm text-heart hover:bg-heart/5 transition-colors"
                                                   onclick="return confirm('{{ 'admin.action.archive.confirmation'|trans({}, 'admin') }}')">
                                                    <i data-lucide="archive" class="size-4"></i>
                                                    {{ 'admin.action.archive.label'|trans({}, 'admin') }}
                                                </a>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </div>
                                {% endblock %}
                                </td>
                            </tr>
                        {% endfor %}
                    {% endif %}
                </tbody>
            </table>
        {% endblock %}
        </div>

        {# Pagination footer - always visible #}
        <div class="px-4 py-3 border-t border-zinc-200 flex items-center justify-between bg-zinc-50 shrink-0">
            <div class="text-xs text-zinc-500">
                {% if pager is defined %}
                    <span class="font-medium text-zinc-700">{{ collection|length }}</span> / {{ pager.nbRecords }} {{ 'admin.list.results'|trans({}, 'admin') }}
                {% elseif collection is defined %}
                    <span class="font-medium text-zinc-700">{{ collection|length }}</span> {{ 'admin.list.results'|trans({}, 'admin') }}
                {% endif %}
            </div>
            {% if pager is defined and pager.pages|length > 1 %}
            <div class="flex items-center gap-1">
                {# Previous #}
                {% if pager.page > 1 %}
                <a href="?page={{ pager.page - 1 }}&limit={{ pager.nbPerPage }}"
                   class="p-1.5 text-zinc-500 hover:text-zinc-700 hover:bg-zinc-200 rounded transition-colors">
                    <i data-lucide="chevron-left" class="size-4"></i>
                </a>
                {% else %}
                <span class="p-1.5 text-zinc-300">
                    <i data-lucide="chevron-left" class="size-4"></i>
                </span>
                {% endif %}

                {# Page numbers #}
                {% for p in pager.pages %}
                    {% if p == pager.page %}
                    <span class="px-3 py-1 text-sm font-medium text-white bg-primary rounded">{{ p }}</span>
                    {% elseif p == 1 or p == pager.pages|last or (p >= pager.page - 2 and p <= pager.page + 2) %}
                    <a href="?page={{ p }}&limit={{ pager.nbPerPage }}"
                       class="px-3 py-1 text-sm text-zinc-600 hover:bg-zinc-200 rounded transition-colors">{{ p }}</a>
                    {% elseif p == 2 or p == pager.pages|last - 1 %}
                    <span class="px-1 text-zinc-400">...</span>
                    {% endif %}
                {% endfor %}

                {# Next #}
                {% if pager.page < pager.pages|length %}
                <a href="?page={{ pager.page + 1 }}&limit={{ pager.nbPerPage }}"
                   class="p-1.5 text-zinc-500 hover:text-zinc-700 hover:bg-zinc-200 rounded transition-colors">
                    <i data-lucide="chevron-right" class="size-4"></i>
                </a>
                {% else %}
                <span class="p-1.5 text-zinc-300">
                    <i data-lucide="chevron-right" class="size-4"></i>
                </span>
                {% endif %}
            </div>
            {% endif %}
        </div>
    </div>
</div>
<div class="hidden">
    {{ form_rest(form) }}
</div>
{{ form_end(form) }}
