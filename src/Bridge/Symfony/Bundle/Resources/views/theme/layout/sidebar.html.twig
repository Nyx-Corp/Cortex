<button id="sidebar-toggle" class="absolute -end-2 top-1/2 z-10 -translate-y-1/2 rounded-full border border-layout-border bg-[var(--color-menu-bg)] p-1 text-white hover:bg-[var(--color-menu-bg-lighter)]">
	<i data-lucide="chevron-left" class="size-3 group-[.closed]/sidebar:hidden"></i>
	<i data-lucide="chevron-right" class="size-3 hidden group-[.closed]/sidebar:block"></i>
</button>

{# Logo #}
<div class="flex items-center justify-center h-20 group-[.closed]/sidebar:h-14 px-4 pt-4 group-[.closed]/sidebar:p-2">
	<div class="flex items-center justify-center h-full transition-all duration-300">
		<img src="{% block logo_url '' %}" alt="Logo" class="w-auto h-full object-contain">
	</div>
</div>

{# Search button - triggers Cmd+K modal #}
<div class="px-3 pt-4 pb-3">
	<button id="search-trigger" class="w-full flex items-center gap-3 px-3 py-2 rounded-md text-sm text-gray-400 bg-menu-bg-lighter hover:bg-menu-hover hover:text-white transition-colors group-[.closed]/sidebar:justify-center">
		<i data-lucide="search" class="size-4 shrink-0"></i>
		<span class="group-[.closed]/sidebar:hidden flex-1 text-left">Rechercher...</span>
		<kbd class="group-[.closed]/sidebar:hidden text-xs bg-menu-bg px-1.5 py-0.5 rounded text-gray-500">⌘K</kbd>
	</button>
</div>

{# Navigation menu #}
<nav class="flex flex-1 flex-col overflow-y-auto">
	<ul class="flex flex-1 flex-col overflow-hidden gap-y-7">
	{% for section in menu|default([]) %}
		{{ render_block('menu_section', '@_theme/components/menu.html.twig', {
			section: section,
			active_menu: active_menu,
		}) }}
	{% endfor %}
	</ul>
	{% if menu_bottom|default([])|length > 0 %}
	<ul class="flex flex-col gap-y-7 mt-auto py-4 border-t border-menu-border">
	{% for section in menu_bottom %}
		{{ render_block('menu_section', '@_theme/components/menu.html.twig', {
			section: section,
			active_menu: active_menu,
		}) }}
	{% endfor %}
	</ul>
	{% endif %}
</nav>

{# Club Switcher + Profile - Style Payfit #}
{% block club_switcher %}
<div class="border-t border-menu-border">
	<div class="px-2 py-3 group/switcher relative z-50">
		<div class="flex items-center gap-3 rounded-md px-3 py-2 cursor-pointer hover:bg-menu-hover transition-colors">
			{# Club avatar/initials #}
			<div class="size-9 shrink-0 rounded-lg bg-primary flex items-center justify-center text-white font-semibold text-sm">
				{# TODO: Dynamic club initials #}
				CB
			</div>
			{# Club info - hidden when collapsed #}
			<div class="flex-1 min-w-0 group-[.closed]/sidebar:hidden">
				{# TODO: Dynamic club name #}
				<p class="text-sm font-medium text-white truncate">Cercle de Bridge de Caluire</p>
				{# TODO: Dynamic role #}
				<p class="text-xs text-gray-400 truncate">Admin</p>
			</div>
			<i data-lucide="chevrons-up-down" class="size-4 text-gray-400 group-[.closed]/sidebar:hidden"></i>
		</div>

		{# Dropdown menu - pb-2 creates invisible bridge to prevent hover loss #}
		<div class="absolute bottom-full inset-x-2 pb-2
				z-50 pointer-events-none opacity-0 scale-95 origin-bottom
				transition-all duration-150
				w-[236px] left-2
				group-hover/switcher:opacity-100 group-hover/switcher:scale-100 group-hover/switcher:pointer-events-auto">
			<div class="rounded-lg bg-menu-bg-lighter border border-menu-border shadow-xl">

			{# Current club header #}
			<div class="px-4 py-3 border-b border-menu-border">
				<p class="text-sm font-medium text-white">Cercle de Bridge de Caluire</p>
				<span class="inline-flex items-center mt-1 px-2 py-0.5 rounded text-xs font-medium bg-primary text-white">
					Admin
				</span>
			</div>

			{# Menu items #}
			<div class="py-2">
				<a href="#" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-300 hover:text-white hover:bg-menu-hover transition-colors">
					<i data-lucide="settings" class="size-4"></i>
					<span>Mes paramètres</span>
				</a>
				<a href="#" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-300 hover:text-white hover:bg-menu-hover transition-colors">
					<i data-lucide="help-circle" class="size-4"></i>
					<span>Aide / Support</span>
				</a>
			</div>

			{# Switch club section #}
			<div class="border-t border-menu-border py-2">
				<p class="px-4 py-1 text-xs font-medium text-gray-500 uppercase tracking-wide">Changer de club</p>
				{# TODO: Dynamic club list from user roles #}
				<a href="#" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-300 hover:text-white hover:bg-menu-hover transition-colors">
					<div class="size-7 rounded bg-menu-hover flex items-center justify-center text-xs font-medium">RN</div>
					<div class="flex-1 min-w-0">
						<p class="truncate">Le Rouge et le Noir</p>
						<p class="text-xs text-gray-500">Membre</p>
					</div>
				</a>
				<a href="#" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-300 hover:text-white hover:bg-menu-hover transition-colors">
					<div class="size-7 rounded bg-menu-hover flex items-center justify-center text-xs font-medium">BL</div>
					<div class="flex-1 min-w-0">
						<p class="truncate">Bridge Club Lyon</p>
						<p class="text-xs text-gray-500">Admin</p>
					</div>
				</a>
			</div>

			{# Logout #}
			<div class="border-t border-menu-border py-2">
				<a href="#" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-300 hover:text-white hover:bg-menu-hover transition-colors">
					<i data-lucide="log-out" class="size-4"></i>
					<span>Déconnexion</span>
				</a>
			</div>
			</div>{# /inner dropdown content #}
		</div>{# /dropdown wrapper with padding bridge #}
	</div>
</div>
{% endblock %}
