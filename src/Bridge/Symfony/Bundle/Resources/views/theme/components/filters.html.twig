{% use "form_div_layout.html.twig" %}

{# Text input #}
{% block text_row %}
    <div class="mt-2">
        <div class="flex items-center justify-between mb-1">
            <label class="block text-xs text-foreground italic">{{ (form.vars.label ?: form.vars.name|humanize)|trans }}</label>
        </div>
        <div class="mt-1">
            {% set attr = attr|merge({
                'placeholder': (form.vars.label ?: form.vars.name|humanize)|trans,
                'class': 'block w-full rounded-md bg-card px-3 py-1.5 text-sm text-foreground outline-1 -outline-offset-1 outline-input placeholder:text-muted-foreground placeholder:italic focus:outline-2 focus:-outline-offset-2 focus:outline-primary'
            }) %}
            {{ form_widget(form, { attr: attr }) }}
        </div>
    </div>
{% endblock %}


{# Choice field - handles both select and radio #}
{% block choice_row %}
    <div class="mt-2">
        <div class="flex items-center justify-between mb-1">
            <label class="block text-xs text-foreground italic">{{ (form.vars.label ?: form.vars.name|humanize)|trans }}</label>
        </div>
        <div class="mt-1">
            {% if expanded %}
                {# Radio buttons as segmented controls #}
                <div class="w-full inline-flex overflow-hidden border border-input rounded-md">
                    {% for child in form %}
                        {% if child.vars.value == '' %}
                            {# Transform the empty choice into "Tout" #}
                            <label class="cursor-pointer flex-1 {% if not loop.first %}border-l border-input{% endif %}">
                                {% set child_attr = child.vars.attr|merge({
                                    'class': 'sr-only peer'
                                }) %}
                                {{ form_widget(child, { attr: child_attr }) }}
                                <div class="px-2 py-1.5 text-xs font-medium text-muted-foreground italic bg-muted hover:bg-accent hover:text-foreground peer-checked:bg-card peer-checked:text-foreground peer-checked:not-italic text-center transition-colors">
                                    Tout
                                </div>
                            </label>
                        {% else %}
                            {# Regular choices #}
                            <label class="cursor-pointer flex-1 {% if not loop.first %}border-l border-input{% endif %}">
                                {% set child_attr = child.vars.attr|merge({
                                    'class': 'sr-only peer'
                                }) %}
                                {{ form_widget(child, { attr: child_attr }) }}
                                <div class="px-2 py-1.5 text-xs font-medium text-muted-foreground italic bg-muted hover:bg-accent hover:text-foreground peer-checked:bg-card peer-checked:text-foreground peer-checked:not-italic text-center transition-colors">
                                    {{ child.vars.label|trans }}
                                </div>
                            </label>
                        {% endif %}
                    {% endfor %}
                </div>
            {% else %}
                {# Select dropdown for non-expanded choices #}
                <div class="relative w-full">
                    {% set attr = attr|merge({
                        'class': 'block w-full appearance-none rounded-md bg-card pl-3 pr-10 py-1.5 text-sm text-foreground outline-1 -outline-offset-1 outline-input focus:outline-2 focus:-outline-offset-2 focus:outline-primary cursor-pointer'
                    }) %}
                    <select {{ block('widget_attributes') }} {{ multiple ? 'multiple="multiple"' : '' }}>
                        {% if required is not true %}
                            <option value="">{{ placeholder is defined ? placeholder|trans : 'form.select.empty_value'|trans({}, 'admin') }}</option>
                        {% endif %}
                        {% for group_label, choice in choices %}
                            {%- if choice is iterable -%}
                                <optgroup label="{{ choice_translation_domain is same as(false) ? group_label : group_label|trans({}, choice_translation_domain) }}">
                                    {% for nested_choice in choice %}
                                        <option value="{{ nested_choice.value }}"{% if nested_choice.attr %} {% set attr = nested_choice.attr %}{% for attrname, attrvalue in attr %} {{ attrname }}="{{ attrvalue }}"{% endfor %}{% endif %}{% if nested_choice is selectedchoice(value) %} selected="selected"{% endif %}>{{ choice_translation_domain is same as(false) ? nested_choice.label : nested_choice.label|trans({}, choice_translation_domain) }}</option>
                                    {% endfor %}
                                </optgroup>
                            {%- else -%}
                                <option value="{{ choice.value }}"{% if choice.attr %} {% set attr = choice.attr %}{% for attrname, attrvalue in attr %} {{ attrname }}="{{ attrvalue }}"{% endfor %}{% endif %}{% if choice is selectedchoice(value) %} selected="selected"{% endif %}>{{ choice_translation_domain is same as(false) ? choice.label : choice.label|trans({}, choice_translation_domain) }}</option>
                            {%- endif -%}
                        {% endfor %}
                    </select>
                    <i data-lucide="chevron-down" class="absolute right-2 top-1/2 -translate-y-1/2 size-3 text-muted-foreground pointer-events-none"></i>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}

{# Radio buttons with horizontal layout #}
{% block radio_row %}
    <div class="space-y-2 mt-3 xl:mt-0">
        <div class="flex items-center gap-2 mb-1">
            <label class="block text-xs text-foreground italic">{{ (form.vars.label ?: form.vars.name|humanize)|trans }}</label>
        </div>
        <div class="flex items-center gap-4">
            {% for choice in choices %}
                <label class="flex items-center gap-2 cursor-pointer">
                    {% set radio_attr = {
                        'class': 'text-primary focus:ring-primary'
                    } %}
                    <input type="radio"
                           name="{{ full_name }}"
                           value="{{ choice.value }}"
                           {% if choice is selectedchoice(value) %}checked{% endif %}
                           {{ block('widget_attributes') }}
                           {% for attrname, attrvalue in radio_attr %} {{ attrname }}="{{ attrvalue }}"{% endfor %}>
                    <span class="text-sm text-foreground">{{ choice_translation_domain is same as(false) ? choice.label : choice.label|trans({}, choice_translation_domain) }}</span>
                </label>
            {% endfor %}
        </div>
    </div>
{% endblock %}

{# Checkbox as switch toggle #}
{% block checkbox_row %}
    <div class="mt-2">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
                <label class="text-xs text-foreground italic">{{ (form.vars.label ?: form.vars.name|humanize)|trans({}, form.vars.translation_domain) }}</label>
            </div>
            <label class="relative inline-flex items-center cursor-pointer">
                {% set attr = attr|merge({
                    'class': 'sr-only peer'
                }) %}
                {{ form_widget(form, { attr: attr }) }}
                <div class="relative w-11 h-6 bg-input peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-primary rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-card after:border-input after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
            </label>
        </div>
    </div>
{% endblock %}

{# Radio widget with conditional sort styling #}
{% block radio_widget %}
    {% if attr['data-sort-direction'] is defined %}
        {# Widget spécial pour les radios de tri #}
        {% set direction = attr['data-sort-direction'] %}
        {% set icon = direction == 'asc' ? 'chevron-up' : 'chevron-down' %}
        <label class="cursor-pointer {{ checked ? 'text-primary' : 'text-muted-foreground' }} hover:text-primary transition-colors">
            {% set attr = attr|merge({'class': 'sr-only', 'data-autosubmit': 'true'}) %}
            <input type="radio" {{ block('widget_attributes') }} value="{{ value }}"{% if checked %} checked="checked"{% endif %}>
            <i data-lucide="{{ icon }}" class="{{ checked ? 'size-5' : 'size-4' }}"></i>
        </label>
    {% else %}
        {# Radio normal pour les filtres #}
        {{ parent() }}
    {% endif %}
{% endblock %}


{# Override default form_row to prevent wrapper divs #}
{% block form_row %}
    {% if form.vars.block_prefixes[1] is defined %}
        {% set widget_type = form.vars.block_prefixes[1] %}
        {% if widget_type == 'text' %}
            {{ block('text_row') }}
        {% elseif widget_type == 'choice' or widget_type == 'enum' or 'choice' in form.vars.block_prefixes %}
            {{ block('choice_row') }}
        {% elseif widget_type == 'checkbox' %}
            {{ block('checkbox_row') }}
        {% else %}
            {{ form_widget(form) }}
        {% endif %}
    {% else %}
        {{ form_widget(form) }}
    {% endif %}
{% endblock %}
