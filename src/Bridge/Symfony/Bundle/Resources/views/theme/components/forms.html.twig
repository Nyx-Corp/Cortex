{% use "form_div_layout.html.twig" %}

{%- block form_row -%}
    {% if compound %}
        {{- form_rest(form) -}}
    {% else %}
        {%- set widget_attr = {} -%}
        {%- if help is not empty -%}
            {%- set widget_attr = { attr:{'aria-describedby': id ~"_help" }} -%}
        {%- endif -%}
        {% set row_attr = { class: 'sm:col-span-4'}|merge(row_attr|default({})) %}
        {% set label_container_attr = { class: 'flex items-center gap-3'}|merge(label_container_attr|default({})) %}
        {% set widget_container_attr = { class: 'mt-2'}|merge(widget_container_attr|default({})) %}
        <div{% with { attr: row_attr } %}{{ block('attributes') }}{% endwith %}>
            <div {% with { attr: label_container_attr } %}{{ block('attributes') }}{% endwith %}>
                {{- form_label(form) -}}
                {{- form_help(form) -}}
            </div>
            <div {% with { attr: widget_container_attr } %}{{ block('attributes') }}{% endwith %}>
                {{- form_widget(form, widget_attr) -}}
            </div>
            {{- form_errors(form) -}}
        </div>
    {% endif %}
{%- endblock form_row -%}

{% block form_label %}
    {% set label_attr = {'class': 'text-sm/6 font-medium text-foreground'} | merge(label_attr|default({})) %}
    {% if label is not same as(false) %}
        {% if label is empty %}
            {% set label = name|humanize %}
        {% endif %}
        <label{% if id is not empty %} for="{{ id }}"{% endif %}{% with { attr: label_attr } %}{{ block('attributes') }}{% endwith %}>
            {{- label|trans(label_translation_parameters, translation_domain) -}}
            {%- if required %}<span class="text-primary ml-0.5">*</span>{% endif -%}
        </label>
    {% endif %}
{% endblock %}

{% block form_widget_simple %}
    {% set attr = {
        class: 'block appearance-none w-full rounded-md bg-card px-3 py-1.5 text-base text-foreground outline-1 -outline-offset-1 outline-input placeholder:text-muted-foreground placeholder:italic focus:outline-2 focus:-outline-offset-2 focus:outline-primary sm:text-sm/6',
        placeholder: placeholder|default(false)
    } | merge(attr|default({})) %}
    {{ parent() }}
{% endblock %}

{% block email_widget %}
    <div class="relative">
        <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
            <i data-lucide="mail" class="size-4 text-muted-foreground"></i>
        </div>
        {% set type = 'email' %}
        {% set attr = attr|default({})|merge({class: '!pl-10 ' ~ (attr.class|default(''))}) %}
        {{ parent() }}
    </div>
{% endblock %}

{% block tel_widget %}
    <div class="relative">
        <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
            <i data-lucide="phone" class="size-4 text-muted-foreground"></i>
        </div>
        {% set type = 'tel' %}
        {% set attr = attr|default({})|merge({class: '!pl-10 ' ~ (attr.class|default(''))}) %}
        {{ parent() }}
    </div>
{% endblock %}

{%- block textarea_widget -%}
    {% set attr = {
        class: 'block appearance-none w-full rounded-md bg-card px-3 py-1.5 text-base text-foreground outline-1 -outline-offset-1 outline-input placeholder:text-muted-foreground placeholder:italic focus:outline-2 focus:-outline-offset-2 focus:outline-primary sm:text-sm/6 min-h-[6rem] resize-none',
        placeholder: placeholder|default(false)
    } | merge(attr|default({})) %}
    {{ parent() }}
{%- endblock textarea_widget -%}

{%- block choice_widget_expanded -%}

    {% set label_attr = {'class': 'ml-2 mr-8 block text-sm/6 font-medium text-foreground'} | merge(label_attr|default({})) %}
    
    <div class="flex items-center flex-wrap mt-3 gap-2 sm:flex-nowrap">
    {%- for child in form %}
        {{- form_widget(child, {
            attr: {
                class: 'relative size-4 appearance-none rounded-full
                border border-input bg-card before:absolute before:inset-1 before:rounded-full before:bg-white not-checked:before:hidden checked:border-primary checked:bg-primary focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-medium disabled:border-input disabled:bg-muted disabled:before:bg-muted-foreground forced-colors:appearance-auto forced-colors:before:hidden'
            }
        }) -}}
        {{- form_label(child, null, {
            translation_domain: choice_translation_domain,
            label_attr: label_attr
        }) -}}
    {% endfor -%}
    </div>
{%- endblock choice_widget_expanded -%}
{% block choice_widget_collapsed %}
    <div class="mt-2 relative">
        {% set attr = {
            'class': 'block w-full appearance-none rounded-md bg-card pr-10 px-3 py-1.5 text-base text-foreground outline-1 -outline-offset-1 outline-input placeholder:text-muted-foreground placeholder:italic focus:outline-2 focus:-outline-offset-2 focus:outline-primary sm:text-sm/6'
        } | merge(attr|default({})) %}

        {{ parent() }}

        <i data-lucide="chevrons-up-down" class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 h-4 w-4 text-foreground opacity-70"></i>
    </div>
{% endblock %}

{% block form_help %}
    {% if help is not empty %}
        <div class="relative group shrink-0">
            <i data-lucide="info" class="size-3 text-muted-foreground cursor-help"></i>
            <div class="absolute left-full top-0 ml-2 z-10 hidden group-hover:block min-w-50 max-w-xs text-xs text-muted-foreground bg-card border border-input rounded-md shadow p-2 whitespace-normal">
                {{ help|trans(help_translation_parameters, translation_domain) }}
            </div>
        </div>
    {% endif %}
{% endblock %}
