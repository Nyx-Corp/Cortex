{# Notifications - Fixed top-right of content area #}
<div class="fixed top-4 right-4 z-[80] group/notif">
	<button type="button" class="relative p-2 rounded-full bg-card border border-border shadow-sm hover:bg-muted transition-colors" aria-label="Voir les notifications">
		<i data-lucide="bell" class="size-5 text-foreground"></i>
		{# TODO: Dynamic unread count #}
		<span class="absolute -top-1 -right-1 size-5 flex items-center justify-center text-xs font-medium bg-primary text-white rounded-full">
			3
		</span>
	</button>

	{# Dropdown wrapper - pt-2 creates invisible bridge to prevent hover loss #}
	<div class="absolute top-full right-0 pt-2 w-80
			pointer-events-none opacity-0 scale-95 origin-top-right
			transition-all duration-150
			group-hover/notif:opacity-100 group-hover/notif:scale-100 group-hover/notif:pointer-events-auto">
		<div class="rounded-lg bg-card border border-border shadow-xl">

		{# Header #}
		<div class="flex items-center justify-between px-4 py-3 border-b border-border">
			<h3 class="text-sm font-semibold text-foreground">Notifications</h3>
			<button type="button" class="text-xs text-primary hover:underline">Tout marquer lu</button>
		</div>

		{# Notification list #}
		<div class="max-h-80 overflow-y-auto">
			{# TODO: Dynamic notifications from backend #}

			{# Notification item - unread #}
			<a href="#" class="flex gap-3 px-4 py-3 hover:bg-muted transition-colors border-l-2 border-primary bg-primary/5">
				<div class="size-8 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
					<i data-lucide="trophy" class="size-4 text-primary"></i>
				</div>
				<div class="flex-1 min-w-0">
					<p class="text-sm text-foreground">Nouveaux résultats disponibles</p>
					<p class="text-xs text-muted-foreground mt-0.5">Tournoi du 25 janvier - 32 paires</p>
					<p class="text-xs text-muted-foreground mt-1">Il y a 5 min</p>
				</div>
			</a>

			{# Notification item - unread #}
			<a href="#" class="flex gap-3 px-4 py-3 hover:bg-muted transition-colors border-l-2 border-primary bg-primary/5">
				<div class="size-8 rounded-full bg-info/10 flex items-center justify-center shrink-0">
					<i data-lucide="user-plus" class="size-4 text-info"></i>
				</div>
				<div class="flex-1 min-w-0">
					<p class="text-sm text-foreground">Nouvelle demande d'adhésion</p>
					<p class="text-xs text-muted-foreground mt-0.5">Jean Dupont souhaite rejoindre le club</p>
					<p class="text-xs text-muted-foreground mt-1">Il y a 2 heures</p>
				</div>
			</a>

			{# Notification item - read #}
			<a href="#" class="flex gap-3 px-4 py-3 hover:bg-muted transition-colors border-l-2 border-transparent">
				<div class="size-8 rounded-full bg-success/10 flex items-center justify-center shrink-0">
					<i data-lucide="check-circle" class="size-4 text-success"></i>
				</div>
				<div class="flex-1 min-w-0">
					<p class="text-sm text-foreground">Paiement reçu</p>
					<p class="text-xs text-muted-foreground mt-0.5">Cotisation de Marie Martin validée</p>
					<p class="text-xs text-muted-foreground mt-1">Hier</p>
				</div>
			</a>
		</div>

		{# Footer #}
		<div class="px-4 py-2 border-t border-border bg-muted/50">
			<a href="#" class="text-xs text-primary hover:underline">Voir toutes les notifications</a>
		</div>
		</div>{# /inner dropdown content #}
	</div>{# /dropdown wrapper with padding bridge #}
</div>
