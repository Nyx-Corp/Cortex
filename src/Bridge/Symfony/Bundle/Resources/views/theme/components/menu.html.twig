{% block menu_element %}
    {# Check roles access - skip element if user doesn't have required role #}
    {% set element_roles = element.roles|default([]) %}
    {% if element_roles is not iterable %}{% set element_roles = [element_roles] %}{% endif %}
    {% set has_access = element_roles|length == 0 %}
    {% if not has_access %}
        {% for role in element_roles %}
            {% if is_granted(role) %}{% set has_access = true %}{% endif %}
        {% endfor %}
    {% endif %}
    {% if has_access %}
    {% set active = element.active|default(false) or element.label == active_menu|default('') %}
    {% set disabled = element.disabled|default(false) %}
    {% set premium = element.premium|default(false) %}
    {% set link = disabled ? '#' : (element.link is defined ? element.link : (element.route is defined ? path(element.route, element.routeParams|default({})) : '#')) %}
    <li>
        <a href="{{ link }}" class="flex items-center gap-4 rounded-md p-2 text-sm font-medium group-[.closed]/sidebar:px-0 {{ element.extra_class|default('') }} {{ active ? 'text-white bg-menu-active' : '' }} {{ disabled ? 'opacity-40 cursor-not-allowed' : 'hover:bg-menu-hover hover:text-white' }}"
            {% if disabled %}aria-disabled="true"{% endif %}
        >
        {% if element.icon is defined and element.icon is not empty %}
            <i data-lucide="{{ element.icon }}" class="size-5 group-[.closed]/sidebar:mx-auto"></i>
        {% endif %}
            <span class="group-[.closed]/sidebar:hidden">{{ element.label }}</span>
        {% if premium %}
            <span class="ml-auto flex items-center gap-1 rounded-full bg-gradient-to-r from-amber-500 to-yellow-400 px-2 py-0.5 text-xs text-amber-900 font-semibold group-[.closed]/sidebar:hidden">
                <i data-lucide="crown" class="size-3"></i>
            </span>
        {% elseif element.wip|default(false) %}
            <span class="ml-auto flex items-center gap-1 rounded-full bg-wip px-2 py-0.5 text-xs text-white font-semibold group-[.closed]/sidebar:hidden">
                <i data-lucide="construction" class="size-3"></i>
            </span>
        {% elseif element.pill is defined %}
            <span class="ml-auto rounded-full {{ element.pill.color|default('bg-green-500') }} px-2 text-xs text-white group-[.closed]/sidebar:hidden">
                {{ element.pill.value }}
            </span>
        {% endif %}
        </a>
    </li>
    {% endif %}
{% endblock %}

{% block menu_section %}
    {# Check roles access - skip section if user doesn't have required role #}
    {% set section_roles = section.roles|default([]) %}
    {% if section_roles is not iterable %}{% set section_roles = [section_roles] %}{% endif %}
    {% set has_section_access = section_roles|length == 0 %}
    {% if not has_section_access %}
        {% for role in section_roles %}
            {% if is_granted(role) %}{% set has_section_access = true %}{% endif %}
        {% endfor %}
    {% endif %}
    {% if has_section_access %}
    <li class="{{ section.class|default('group-[.closed]/sidebar:-mt-5')|raw }}">
    {% if section.label is defined %}
    	<h2 class="text-xs font-semibold uppercase tracking-wide text-gray-500">
			<span class="block transition-all duration-300 pl-5 group-[.closed]/sidebar:hidden">
                {{ section.label }}
            </span>
			<span class="hidden group-[.closed]/sidebar:flex h-px w-10 bg-gray-600 mx-auto my-2"></span>
		</h2>
    {% endif %}
        <ul role="list" class="flex flex-col mt-3 group-[.closed]/sidebar:mt-4 gap-y-1 group-[.closed]/sidebar:gap-y-2 mx-3 px-0">
            {% for element in section.elements|default([]) %}
                {{ block('menu_element') }}
            {% endfor %}
        </ul>
    </li>
    {% endif %}
{% endblock %}
