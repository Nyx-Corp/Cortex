{# template route : {module}/{model}/{action} #}

{% trans_default_domain '{module}' %}

{% extends "{module}/{model}/_form.html.twig" %}

{% import '@_theme/components/breadcrumbs.html.twig' as breadcrumbs %}
{% block breadcrumb %}
    {{ parent() }}
    {{ breadcrumbs.item('{model}.create.title'|trans, null, null, true) }}
{% endblock %}

